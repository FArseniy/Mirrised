PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://mirror.erised.click
PENDING_ROOM_TTL_MS=600000
ROOM_IDLE_TTL_MS=1800000
ROOM_MAX_AGE_MS=21600000
MAX_ACTIVE_ROOMS=1000
MAX_PENDING_ROOMS=1000
# A lost mobile connection is released within roughly interval + timeout (8 seconds by default).
SOCKET_PING_INTERVAL_MS=3000
SOCKET_PING_TIMEOUT_MS=5000
STUN_URL=stun:stun.l.google.com:19302
# TURN_URL may contain several comma-separated URLs, for example UDP and TLS.
TURN_URL=turn:trans.erised.click:3478?transport=udp,turns:trans.erised.click:5349?transport=tcp
# Keep this value only on the application server. It must match Coturn static-auth-secret.
TURN_SHARED_SECRET=replace-with-a-random-32-byte-secret
TURN_TTL_SECONDS=3600
# Do not use permanent TURN_USERNAME / TURN_CREDENTIAL in production. They are shown
# only as names commonly used by static TURN setups; this application intentionally
# generates short-lived credentials from TURN_SHARED_SECRET instead.
TURN_USERNAME=
TURN_CREDENTIAL=

